          "name": "FULL FLOW (set clock → create account → subscribe → advance → check invoice)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/1.0/kb/test/clock?requestedDate=2026-01-01T06:00:00.000Z", "host": ["{{base_url}}"], "path": ["1.0", "kb", "test", "clock"], "query": [{"key": "requestedDate", "value": "{{clock_ref}}"}] },
            "header": [
