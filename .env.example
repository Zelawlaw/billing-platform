# =============================================================================
# .env.example — master environment variables for billing-platform.
#
# Copy to .env and fill in values for your target environment.
# Pick the section for local or production below.
# This file is the single source of truth. When you change values here, update
# the matching Postman environment in postman/ too.
# =============================================================================

# =============================================================================
# LOCAL (development on your machine)
# =============================================================================
# KB_URL=http://127.0.0.1:8081
# KB_USER=admin
# KB_PASS=password
# KB_API_KEY=inua
# KB_API_SECRET=inua-secret
# KB_CREATED_BY=billing-platform
# KILLBILL_DAO_URL=jdbc:mysql://db:3306/killbill
# KILLBILL_DAO_USER=root
# KILLBILL_DAO_PASSWORD=killbill
# KILLBILL_SERVER_TEST_MODE=true
# KAUI_CONFIG_DAO_URL=jdbc:mysql://db:3306/kaui
# KAUI_CONFIG_DAO_USER=root
# KAUI_CONFIG_DAO_PASSWORD=killbill
# KAUI_KILLBILL_URL=http://killbill:8080
# KAUI_KILLBILL_API_KEY=bob
# KAUI_KILLBILL_API_SECRET=lazar
# MYSQL_ROOT_PASSWORD=killbill
# FINERACT_URL=http://127.0.0.1:8765/fineract/1.0
# PORT=8000
# DRY_RUN=false
# AUDIT_FILE=/tmp/rating-service-audit.json
# CLOCK_REF=2026-01-01T06:00:00.000Z

# =============================================================================
# PRODUCTION (VPS)
# =============================================================================
KB_URL=http://<VPS_IP>:8080
KB_USER=<CHANGE_ME>
KB_PASS=<CHANGE_ME>
KB_API_KEY=inua
KB_API_SECRET=<CHANGE_ME>
KB_CREATED_BY=billing-platform

# Kill Bill → DB
KILLBILL_DAO_URL=jdbc:mysql://db:3306/killbill
KILLBILL_DAO_USER=root
KILLBILL_DAO_PASSWORD=<CHANGE_ME>
KILLBILL_SERVER_TEST_MODE=false

# Kaui admin UI → DB + KB
KAUI_CONFIG_DAO_URL=jdbc:mysql://db:3306/kaui
KAUI_CONFIG_DAO_USER=root
KAUI_CONFIG_DAO_PASSWORD=<CHANGE_ME>
KAUI_KILLBILL_URL=http://killbill:8080
KAUI_KILLBILL_API_KEY=bob
KAUI_KILLBILL_API_SECRET=<CHANGE_ME>

# MariaDB
MYSQL_ROOT_PASSWORD=<CHANGE_ME>

# ---- Optional services ----
# FINERACT_URL=http://<FINERACT_HOST>/fineract/1.0
# PORT=8000                   # can-proceed? server
# DRY_RUN=false
# AUDIT_FILE=/tmp/rating-service-audit.json
