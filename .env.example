# =============================================================================
# .env.example — master environment variables for billing-platform.
# Copy to .env and fill in your values. This is the single source of truth.
# Update postman/billing-platform.postman_environment.json when you change values.
# =============================================================================

# ---- Kill Bill API (shared by gates, rating service, can-proceed) ----
KB_URL=http://127.0.0.1:8081
KB_USER=admin
KB_PASS=password
KB_API_KEY=inua
KB_API_SECRET=inua-secret
KB_CREATED_BY=billing-platform

# ---- Docker stack ----
# Kill Bill → DB
KILLBILL_DAO_URL=jdbc:mysql://db:3306/killbill
KILLBILL_DAO_USER=root
KILLBILL_DAO_PASSWORD=killbill
KILLBILL_SERVER_TEST_MODE=true

# Kaui admin UI → DB + KB
KAUI_CONFIG_DAO_URL=jdbc:mysql://db:3306/kaui
KAUI_CONFIG_DAO_USER=root
KAUI_CONFIG_DAO_PASSWORD=killbill
KAUI_KILLBILL_URL=http://killbill:8080
KAUI_KILLBILL_API_KEY=bob
KAUI_KILLBILL_API_SECRET=lazar

# MariaDB
MYSQL_ROOT_PASSWORD=killbill

# ---- Rating service (sync.py) ----
FINERACT_URL=http://127.0.0.1:8765/fineract/1.0
DRY_RUN=false
AUDIT_FILE=/tmp/rating-service-audit.json

# ---- can-proceed? server ----
PORT=8000

# ---- Test clock reference date ----
CLOCK_REF=2026-01-01T06:00:00.000Z
